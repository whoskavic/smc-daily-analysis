# ── Binance ───────────────────────────────────────────────────────────────────
# Leave blank to use public endpoints (read-only, no auth needed for market data)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── App ───────────────────────────────────────────────────────────────────────
DAILY_ANALYSIS_TIME=08:00
TIMEZONE=Asia/Jakarta

# Comma-separated list of symbols to analyze (ccxt format)
WATCH_SYMBOLS=["BTC/USDT","ETH/USDT","SOL/USDT"]

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./smc_analysis.db
